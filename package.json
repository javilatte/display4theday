{
  "name": "display4theday",
  "version": "1.0.0",
  "description": "Raspberry Pi dashboard: weather, calendar, news, todos, media and a local AI assistant.",
  "private": true,
  "license": "MIT",
  "main": "server.js",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "postinstall": "node scripts/patch-oauth4webapi.mjs",
    "hash-password": "node scripts/hash-password.mjs",
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node --test test/",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "cookie-session": "^2.1.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ollama": "^0.6.3",
    "openid-client": "^6.8.4",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "eslint": "^9.10.0",
    "globals": "^15.9.0",
    "prettier": "^3.9.0"
  }
}
