# Puerto del servidor
PORT=3000

# Bind address. 127.0.0.1 por defecto (solo local). Cambia a 0.0.0.0 para
# exponer en LAN, o a una IP específica.
HOST=127.0.0.1

# ── Calendar (Google Calendar embed) ────────────────────────────────────
# URL pública de tu Google Calendar, la que obtienes en:
#   Google Calendar → Configuración → [tu calendario] →
#   "Integrar calendario" → "URL pública" → copia "Embed code" → coge
#   solo el valor del atributo `src=...`
# Ejemplo: https://calendar.google.com/calendar/embed?src=tu_id%40group.calendar.google.com&ctz=Europe%2FMadrid
# Para usar varias calendars, sepáralas con coma (el servidor las
# inyecta como `&src=...&src=...` adicional).
# Si está vacío, el panel de calendario muestra instrucciones.
GOOGLE_CALENDAR_EMBED_URL=

# ── AI assistant (optional) ─────────────────────────────────────────────
# Backend de IA. Opciones: ollama | lmstudio | none
# Por defecto "none" → /api/ai/* devuelve 503 con un mensaje claro.
AI_BACKEND=none

# OLLAMA (https://ollama.com) — usado cuando AI_BACKEND=ollama
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=gemma3:12b

# LM Studio (https://lmstudio.ai) — usado cuando AI_BACKEND=lmstudio.
# LM Studio 0.3+ requiere API token. Ábrelo, ve a la pestaña Developer,
# activa "Start Server" y copia el API token que aparece.
LM_STUDIO_HOST=http://127.0.0.1:1234
LM_STUDIO_API_KEY=
LM_STUDIO_MODEL=local-model

# Personalización del asistente IA
OWNER_NAME=el usuario
OWNER_LANGUAGE=español

# ── Media ──────────────────────────────────────────────────────────────
MEDIA_IFRAME_URL=
YOUTUBE_API_KEY=

# ── Auth (optional) ─────────────────────────────────────────────────────
# AUTH_MODE selecciona la estrategia:
#   - "password" → una sola contraseña compartida (DASHBOARD_PASSWORD).
#     Login simple, cookie de sesión firmada. Ideal para home / single-user.
#   - "keycloak" → OIDC contra un realm de Keycloak (más complejo).
#   - (vacío)    → auth deshabilitado, dashboard abierto en la red que
#     sirva (útil para LAN de confianza).
AUTH_MODE=

# Si AUTH_MODE=password:
DASHBOARD_PASSWORD=
SESSION_SECRET=
# Set true si sirves sobre HTTPS (recomendado en producción).
SESSION_COOKIE_SECURE=true

# Si AUTH_MODE=keycloak:
# KEYCLOAK_ISSUER=https://localhost:8443/realms/display4theday
# KEYCLOAK_CLIENT_ID=display4theday
# KEYCLOAK_CLIENT_SECRET=
# KEYCLOAK_REDIRECT_URI=https://localhost:3000/auth/keycloak/callback

# ── Misc ────────────────────────────────────────────────────────────────
# Confiar en X-Forwarded-* de un proxy. 1 = un hop, 2 = dos hops, etc.
# Solo si sirves tras nginx/caddy/cloudflare.
# TRUST_PROXY=1
